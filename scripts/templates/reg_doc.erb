|===

Register fields below use standard notation to show what bits are used in the
register in question.
If a default value other than "all zeros" applies to the register field,
then it follows in parenthesis in decimal form.

<%- conf_regs.sort.each do |r| -%>
=== <%= r %>

Applies to: <%- cfg.each do |p, k| -%>
<%- if cfg[p][r.upcase] -%>
<%= p -%>
<%- end -%>

<%- end -%>

[cols="1s,1,1,1"]
|===
| Field
<%= "^s| " + soc.keys.join("\n^s| ") %>


<%- fields = soc_fields(soc, r) -%>
<%- all_field_names(fields).each do |fname| -%>
| <%= fname -%>
 <%- fields.keys.each do |p| -%>
  <%- if fields[p] -%>
   <%- f = fields[p].find{|h| h[:name] == fname} -%>
    <%- if f -%>

^| <%= f[:width] == 1 ? [f[:pos]] : sprintf("[%d..%d]", f[:width] + f[:pos] - 1, f[:pos]) -%>
<%= f[:default] != 0 ? sprintf(" (%d)", f[:default]) : "" -%>

    <%- else -%>

^| 
    <%- end -%>
  <%- else -%>

^| 
  <%- end -%>
 <%- end -%>
<%- end -%>

